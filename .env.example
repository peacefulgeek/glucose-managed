# ── Glucose Managed — Environment Variables ──────────────────────────────────
# Copy to .env for local dev. Set in Render dashboard for production.
# NO database required — uses JSON file storage (src/data/articles-db.json).

NODE_ENV=development
PORT=3000

# Site URL (no trailing slash)
SITE_URL=https://glucosemanaged.com

# Amazon Associates — affiliate tag
AMAZON_ASSOCIATE_TAG=spankyspinola-20

# Bunny CDN (for image serving — all images are pre-uploaded)
BUNNY_CDN_URL=https://glucose-managed.b-cdn.net
BUNNY_STORAGE_ZONE=glucose-managed
BUNNY_STORAGE_ENDPOINT=https://ny.storage.bunnycdn.com
BUNNY_API_KEY=your_bunny_api_key_here

# OpenAI (only needed for quarterly revision cron — optional in production)
CLAUDE_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Auto-generation (false in production — all 501 articles are pre-seeded)
AUTO_GEN_ENABLED=false
