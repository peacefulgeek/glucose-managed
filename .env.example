# Blood Sugar Blueprint — Environment Variables
# Copy this file to .env and fill in your values

# Server
NODE_ENV=development
PORT=3000

# Database (optional — uses JSON file storage if not set)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# OpenAI (for article generation)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1  # uncomment to use OpenAI directly

# Amazon Associates
AMAZON_ASSOCIATE_TAG=spankyspinola-20

# Bunny CDN (optional — uses local /public/images if not set)
# BUNNY_STORAGE_ZONE=your-storage-zone
# BUNNY_API_KEY=your-bunny-api-key
# BUNNY_CDN_URL=https://your-cdn-url.b-cdn.net

# Site
SITE_URL=https://bloodsugarblueprint.com
