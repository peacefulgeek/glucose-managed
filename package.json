{
  "name": "glucose-managed",
  "version": "1.0.0",
  "description": "Glucose Managed — Prediabetes & Glucose Management Resource",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build",
    "build:server": "node scripts/build-server.mjs",
    "start": "NODE_ENV=production node scripts/start-prod.mjs",
    "seed": "node scripts/bulk-seed.mjs",
    "qa": "node scripts/audit.mjs"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "express": "^4.18.2",
    "invariant": "^2.2.4",
    "marked": "^12.0.0",
    "node-cron": "^3.0.3",
    "openai": "^4.47.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-fast-compare": "^3.2.2",
    "react-helmet-async": "^2.0.4",
    "react-router-dom": "^6.23.1",
    "shallowequal": "^1.1.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "esbuild": "^0.21.4",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-ssr": "^0.4.142"
  }
}
